{
  "name": "shadow-market",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-preserving prediction market and P2P wagering platform on Midnight Network",
  "author": "ShadowMarket Team",
  "license": "MIT",
  "workspaces": [
    "contracts",
    "api",
    "backend",
    "frontend",
    "local-network"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "concurrently \"pnpm:dev:*\"",
    "dev:contracts": "cd contracts && pnpm dev",
    "dev:backend": "cd backend && pnpm dev",
    "dev:frontend": "cd frontend && pnpm dev",
    "build": "pnpm -r build",
    "build:contracts": "cd contracts && pnpm build",
    "build:backend": "cd backend && pnpm build",
    "build:frontend": "cd frontend && pnpm build",
    "test": "pnpm -r test",
    "test:contracts": "cd contracts && vitest run",
    "test:backend": "cd backend && vitest run",
    "test:frontend": "cd frontend && vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "cd backend && pnpm drizzle-kit generate:pg",
    "db:migrate": "cd backend && pnpm drizzle-kit migrate",
    "db:push": "cd backend && pnpm drizzle-kit push:pg",
    "db:seed": "cd backend && tsx src/db/seed.ts",
    "db:studio": "cd backend && pnpm drizzle-kit studio",
    "contracts:compile": "cd contracts && pnpm run compile",
    "contracts:deploy:local": "cd contracts && pnpm run deploy:local",
    "contracts:deploy:testnet": "cd contracts && pnpm run deploy:testnet",
    "network:start": "cd local-network && docker-compose up -d",
    "network:stop": "cd local-network && docker-compose down",
    "network:logs": "cd local-network && docker-compose logs -f",
    "network:reset": "cd local-network && docker-compose down -v && docker-compose up -d",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "clean:all": "pnpm clean && rm -rf **/node_modules **/dist **/.turbo",
    "setup": "pnpm install && pnpm network:start && pnpm contracts:compile && pnpm db:migrate",
    "generate:accounts": "tsx scripts/generate-accounts.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "prediction-market",
    "midnight-network",
    "zero-knowledge",
    "privacy",
    "betting",
    "blockchain",
    "dapp",
    "p2p-wager"
  ]
}
