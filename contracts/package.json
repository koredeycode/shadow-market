{
  "name": "@shadow-market/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "mkdir -p src/managed && compact compile src/market-stub.compact src/managed/market-stub",
    "build": "tsc",
    "dev": "tsc --watch",
    "deploy": "node --loader ts-node/esm --experimental-specifier-resolution=node src/deploy.ts",
    "deploy:local": "MIDNIGHT_NETWORK=local node --loader ts-node/esm --experimental-specifier-resolution=node src/deploy.ts",
    "interact": "node --loader ts-node/esm --experimental-specifier-resolution=node src/interact.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "clean": "rm -rf dist src/managed deployments",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-js": "^2.5.0",
    "@midnight-ntwrk/compact-runtime": "^0.15.0",
    "@midnight-ntwrk/midnight-js-contracts": "^4.0.2",
    "@midnight-ntwrk/midnight-js-types": "^4.0.2",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "^4.0.2",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "^4.0.2",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "^4.0.2",
    "@types/ws": "^8.5.13",
    "ts-node": "^10.9.2",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "^4.0.2",
    "@midnight-ntwrk/midnight-js-network-id": "^4.0.2",
    "@midnight-ntwrk/midnight-js-utils": "^4.0.2",
    "@midnight-ntwrk/ledger-v7": "^7.0.2",
    "@midnight-ntwrk/wallet-sdk-abstractions": "^2.0.0",
    "@midnight-ntwrk/wallet-sdk-address-format": "^3.0.1",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "^2.0.0",
    "@midnight-ntwrk/wallet-sdk-facade": "^2.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "^3.0.0",
    "@midnight-ntwrk/wallet-sdk-shielded": "^2.0.0",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "^2.0.0",
    "rxjs": "^7.8.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
