# ==============================================
# ShadowMarket Environment Configuration
# ==============================================
# Copy this file to .env.local (dev) or .env.production (prod)

# ----------------------------------------------
# Midnight Network Configuration
# ----------------------------------------------
MIDNIGHT_NETWORK_ID=undeployed
MIDNIGHT_NODE_URL=ws://localhost:9944
MIDNIGHT_INDEXER_URL=http://localhost:8088/api/v3/graphql
MIDNIGHT_INDEXER_WS=ws://localhost:8088/api/v3/graphql/ws
MIDNIGHT_PROOF_SERVER_URL=http://localhost:6300

# ----------------------------------------------
# Admin Configuration (Dual-Layer Auth)
# ----------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
# The Midnight wallet address that is allowed to access admin features
ADMIN_ADDRESS=
# The seed phrase or private key used for deployment and initialization
ADMIN_SEED=

# ----------------------------------------------
# Backend Configuration
# ----------------------------------------------
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shadowmarket

# Redis
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# Session & Security
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# ----------------------------------------------
# Frontend Configuration (VITE_ prefix)
# ----------------------------------------------
VITE_API_URL=http://localhost:3000
VITE_MIDNIGHT_NETWORK_ID=undeployed
VITE_MIDNIGHT_NODE_URL=ws://localhost:9944
VITE_MIDNIGHT_INDEXER_URL=http://localhost:8088/api/v3/graphql
VITE_ADMIN_ADDRESS=

# Feature Flags
VITE_ENABLE_P2P_WAGERS=true
VITE_ENABLE_LIQUIDITY_POOLS=true
VITE_ENABLE_ORACLE_REGISTRATION=true

# ----------------------------------------------
# Contract Addresses
# ----------------------------------------------
# These will be filled in after deploying contracts
MIDNIGHT_SHADOW_MARKET_CONTRACT_ADDRESS=
