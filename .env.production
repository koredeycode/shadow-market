# Midnight Network Configuration (Prepod Testnet)
MIDNIGHT_NETWORK_ID=prepod
MIDNIGHT_NODE_URL=https://rpc.prepod.midnight.network
MIDNIGHT_INDEXER_URL=https://indexer.prepod.midnight.network/api/v3/graphql
MIDNIGHT_INDEXER_WS=wss://indexer.prepod.midnight.network/api/v3/graphql/ws
MIDNIGHT_PROOF_SERVER_URL=https://proof-server.prepod.midnight.network

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=    # SET THIS
ADMIN_ADDRESS=     # SET THIS
ADMIN_SEED=        # SET THIS (Mnemonic or Private Key)

# Backend Configuration
PORT=3000
NODE_ENV=production
API_URL=           # SET THIS (e.g., https://api.shadowmarket.com)
DATABASE_URL=      # SET THIS
REDIS_URL=         # SET THIS
SESSION_SECRET=    # SET THIS (Minimum 32 chars)
JWT_SECRET=        # SET THIS (Minimum 32 chars)

# Frontend Configuration
VITE_API_URL=      # SET THIS
VITE_MIDNIGHT_NETWORK_ID=prepod
VITE_MIDNIGHT_NODE_URL=https://rpc.prepod.midnight.network
VITE_MIDNIGHT_INDEXER_URL=https://indexer.prepod.midnight.network/api/v3/graphql
VITE_ADMIN_ADDRESS= # SET THIS

# Contract Addresses
MIDNIGHT_SHADOW_MARKET_CONTRACT_ADDRESS= # SET THIS
